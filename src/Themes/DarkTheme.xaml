<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Catppuccin Mocha Colors -->
    <Color x:Key="BgColor">#1e1e2e</Color>
    <Color x:Key="FgColor">#cdd6f4</Color>
    <Color x:Key="HeadingBgColor">#313244</Color>
    <Color x:Key="MutedFgColor">#a6adc8</Color>
    <Color x:Key="SubtleFgColor">#6c7086</Color>
    <Color x:Key="SelectBgColor">#45475a</Color>
    <Color x:Key="CardBgColor">#24273a</Color>
    <Color x:Key="ChipBgColor">#181825</Color>
    <Color x:Key="AccentPurple">#cba6f7</Color>
    <Color x:Key="WaitingBgColor">#1a3a2a</Color>
    <Color x:Key="ProcessingBgColor">#3a1a1a</Color>
    <Color x:Key="WaitingAccent">#a6e3a1</Color>
    <Color x:Key="ProcessingAccent">#f38ba8</Color>
    <Color x:Key="WaitingBadgeBg">#2f6549</Color>
    <Color x:Key="ProcessingBadgeBg">#6c2742</Color>
    <Color x:Key="BorderColor">#585b70</Color>

    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}" />
    <SolidColorBrush x:Key="FgBrush" Color="{StaticResource FgColor}" />
    <SolidColorBrush x:Key="HeadingBgBrush" Color="{StaticResource HeadingBgColor}" />
    <SolidColorBrush x:Key="MutedFgBrush" Color="{StaticResource MutedFgColor}" />
    <SolidColorBrush x:Key="SubtleFgBrush" Color="{StaticResource SubtleFgColor}" />
    <SolidColorBrush x:Key="SelectBgBrush" Color="{StaticResource SelectBgColor}" />
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}" />
    <SolidColorBrush x:Key="ChipBgBrush" Color="{StaticResource ChipBgColor}" />
    <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource AccentPurple}" />
    <SolidColorBrush x:Key="WaitingBgBrush" Color="{StaticResource WaitingBgColor}" />
    <SolidColorBrush x:Key="ProcessingBgBrush" Color="{StaticResource ProcessingBgColor}" />
    <SolidColorBrush x:Key="WaitingAccentBrush" Color="{StaticResource WaitingAccent}" />
    <SolidColorBrush x:Key="ProcessingAccentBrush" Color="{StaticResource ProcessingAccent}" />
    <SolidColorBrush x:Key="WaitingBadgeBgBrush" Color="{StaticResource WaitingBadgeBg}" />
    <SolidColorBrush x:Key="ProcessingBadgeBgBrush" Color="{StaticResource ProcessingBadgeBg}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />

    <!-- ScrollBar Style -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="{StaticResource BgBrush}" />
    </Style>

    <!-- Button Style -->
    <Style x:Key="AccentButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource SelectBgBrush}" />
        <Setter Property="Foreground" Value="{StaticResource FgBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#585b70" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#6c7086" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- CheckBox Style -->
    <Style x:Key="DarkCheckBox" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource FgBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- DataGrid Styles -->
    <Style TargetType="DataGrid" x:Key="DarkDataGrid">
        <Setter Property="Background" Value="{StaticResource BgBrush}" />
        <Setter Property="Foreground" Value="{StaticResource FgBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="RowBackground" Value="Transparent" />
        <Setter Property="AlternatingRowBackground" Value="Transparent" />
        <Setter Property="HorizontalGridLinesBrush" Value="#2a2b3d" />
        <Setter Property="VerticalGridLinesBrush" Value="#2a2b3d" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="RowHeaderWidth" Value="0" />
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="CanUserDeleteRows" Value="False" />
        <Setter Property="CanUserReorderColumns" Value="False" />
        <Setter Property="CanUserSortColumns" Value="False" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="SelectionMode" Value="Single" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource HeadingBgBrush}" />
        <Setter Property="Foreground" Value="{StaticResource FgBrush}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="BorderBrush" Value="#2a2b3d" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource FgBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="MinHeight" Value="32" />
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource SelectBgBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Restore Button Style -->
    <Style x:Key="RestoreButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource HeadingBgBrush}" />
        <Setter Property="Foreground" Value="{StaticResource FgBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="24,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#585b70" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
